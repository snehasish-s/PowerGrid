# ---- Java / Maven ----
backend/target/
*.class
*.jar
*.war
*.log
*.iml

# ---- Node / React ----
frontend/node_modules/
frontend/dist/
frontend/.env.local

# ---- Python ----
ml-service/__pycache__/
ml-service/*.pyc
ml-service/.venv/
ml-service/venv/
